e=(10, 4))\nplt.plot(calm_attention, label='Calm Market (Wide/Blurred)', marker='o')\nplt.plot(volatile_attention, label='Volatile Market (Sharp/Focused)', marker='s')\nplt.title(\"How Volatility 'Sharpens' the AI's Focus\")\nplt.legend()\nplt.xticks(range(5), [\"Day -4\", \"Day -3\", \"Day -2\", \"Day -1\", \"Today\"])\nplt.show()\n","key":"QDgXRZgStn"},{"type":"outputs","id":"k3GQOc5g5MxoGtS6jvp-j","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"1012188548bd9383f6f5cefe337626e5","path":"/1012188548bd9383f6f5cefe337626e5.png"},"text/plain":{"content":"<Figure size 1000x400 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"FjcyZxT38l"}],"key":"YwnGm8piOW"}],"key":"r9lmsfKa3K"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"5. Building the “Volatility Meter” (Feature Engineering)","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"dHQFTZ0ahG"}],"identifier":"id-5-building-the-volatility-meter-feature-engineering","label":"5. Building the “Volatility Meter” (Feature Engineering)","html_id":"id-5-building-the-volatility-meter-feature-engineering","implicit":true,"key":"x92Zk9eToY"},{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"To help the AI know when to sharpen its focus, we calculate several types of volatility:","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"G21q1jR0o8"}],"key":"NGbDQtBWyD"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":5,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"paragraph","children":[{"type":