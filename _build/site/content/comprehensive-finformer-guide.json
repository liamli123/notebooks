alm Market (Wide/Blurred)', marker='o')\nplt.plot(volatile_attention, label='Volatile Market (Sharp/Focused)', marker='s')\nplt.title(\"How Volatility 'Sharpens' the AI's Focus\")\nplt.legend()\nplt.xticks(range(5), [\"Day -4\", \"Day -3\", \"Day -2\", \"Day -1\", \"Today\"])\nplt.show()\n","key":"rl9Xv7N0zR"},{"type":"outputs","id":"29dacYK4PdHv3-18JLN4D","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"1012188548bd9383f6f5cefe337626e5","path":"/1012188548bd9383f6f5cefe337626e5.png"},"text/plain":{"content":"<Figure size 1000x400 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"wQBgWcpQUj"}],"key":"TyiWifLi4I"}],"key":"rYF1th48lc"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"5. Building the “Volatility Meter” (Feature Engineering)","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"wgdRfqktrQ"}],"identifier":"id-5-building-the-volatility-meter-feature-engineering","label":"5. Building the “Volatility Meter” (Feature Engineering)","html_id":"id-5-building-the-volatility-meter-feature-engineering","implicit":true,"key":"iySHMSmV6D"},{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"To help the AI know when to sharpen its focus, we calculate several types of volatility:","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"Zn5JIGOKvH"}],"key":"Gj9NhY5uzd"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":5,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Historical Volatility","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"ZaqIgxsbOL"}],"key":"Qwy91hAbJi"},{"type":"text","value":": Standard deviation of recent returns.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"XNOIe6lr6W"}],"key":"gS8usn1FKf"}],"key":"kbRqWPHvfO"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"Parkinson Volatility","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"q1OUZDtHeN"}],"key":"F0gT63OXc2"},{"type":"text","value":": Uses the High and Low prices (more info than just Close).","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"Rp8Uh2UFoZ"}],"key":"Pk1IqDl6Iq"}],"key":"ZZdZx6vCJt"},{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"GARCH(1,1)","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"ZxkVY4cS2R"}],"key":"DRkSg3ziq1"},{"type":"text","value":": A statistical model that predicts ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"BgJ0cSdgEu"},{"type":"emphasis","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"tomorrow’s","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"fvzs5x3XKx"}],"key":"siEHU2ZnTk"},{"type":"text","value":" volatility based on today’s.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"Uya6IP7rRn"}],"key":"Pf8uGIHJdX"}],"key":"fx83gYdPna"}],"key":"uSF6xfPWVG"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Let’s load the ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"aHPIeXewMt"},{"type":"strong","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"CSI 300","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"f5gDu08Pfn"}],"key":"dw5g2Et5ec"},{"type":"text","value":" data and look at these “Regimes.”","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"lJPn3elD1h"}],"key":"A3oOgEER6D"}],"key":"wMgrdd9Ym9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"\nimport os\n# Load real CSI 300 data\ndata_path = os.path.join('..', 'data', 'raw', 'csi300_daily.csv')\ndf = pd.read_csv(data_path)\ndf['trade_date'] = pd.to_datetime(df['trade_date'])\ndf['returns'] = df['close'].pct_change()\n\n# Calculate 20-day Volatility\ndf['vol_20d'] = df['returns'].rolling(20).std()\n\n# Visualize the Regimes\nplt.figure(figsize=(14, 7))\nplt.subplot(2, 1, 1)\nplt.plot(df['trade_date'], df['close'])\nplt.title(\"CSI 300 Index Price\")\n\nplt.subplot(2, 1, 2)\nplt.fill_between(df['trade_date'], df['vol_20d'], color='red', alpha=0.3)\nplt.title(\"Market 'Craziness' (20-Day Volatility)\")\nplt.tight_layout()\nplt.show()\n","key":"toDlOoxPew"},{"type":"outputs","id":"YNzHWCnCdS2TLhhU-Rh7y","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"070fb99b4bb08c64b5d324f46bd17119","path":"/070fb99b4bb08c64b5d324f46bd17119.png"},"text/plain":{"content":"<Figure size 1400x700 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"qmxg5cfiV0"}],"key":"sg9iwys8DF"}],"key":"IlApfck0rc"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"6. Implementing the VAA Layer (Simplified)","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"MCwOff52VA"}],"identifier":"id-6-implementing-the-vaa-layer-simplified","label":"6. Implementing the VAA Layer (Simplified)","html_id":"id-6-implementing-the-vaa-layer-simplified","implicit":true,"key":"UO8ruS8R2m"},{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"Here is how the code looks. We use a small “Vol-Net” (a tiny neural network) to decide the spotlight temperature.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"rCx9Eo7L5D"}],"key":"AbcnYzXhQn"}],"key":"VOfLquWl0f"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\n\nclass VolNet(nn.Module):\n    def __init__(self):\n        super().__init__()\n        # Takes 4 volatility scales as input\n        self.net = nn.Sequential(\n            nn.Linear(4, 16),\n            nn.ReLU(),\n            nn.Linear(16, 1), # Outputs 1 temperature scale\n            nn.Sigmoid()      # Keeps it between 0 and 1\n        )\n\n    def forward(self, vol_features):\n        # Maps 0-1 output to a useful scale, e.g., 0.5 to 2.0\n        return self.net(vol_features) * 1.5 + 0.5\n\nprint(\"The 'Thermostat' network is defined.\")\n","key":"mxDCk85gFG"},{"type":"outputs","id":"nOzJNr2lNVj5x9SnB_ddc","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"The 'Thermostat' network is defined.\n"},"children":[],"key":"OEReMJxyqF"}],"key":"mRxUc1WeLV"}],"key":"A0Cup3cvod"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},