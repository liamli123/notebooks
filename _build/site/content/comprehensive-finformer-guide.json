ey":"xzCJS7LNay"}],"key":"eitdLdGsNe"}],"key":"NPEBfimUGM"}],"key":"ZrqCtxNLp8"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Let’s load the ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"XDI2fOCEaH"},{"type":"strong","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"CSI 300","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"Dm1X8Qwzwc"}],"key":"VL2Rjwbslj"},{"type":"text","value":" data and look at these “Regimes.”","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"eTMEIeOUEF"}],"key":"UTiQOVtdK7"}],"key":"KJGf3KY3lh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"\nimport os\n# Load real CSI 300 data\ndata_path = os.path.join('..', 'data', 'raw', 'csi300_daily.csv')\ndf = pd.read_csv(data_path)\ndf['trade_date'] = pd.to_datetime(df['trade_date'])\ndf['returns'] = df['close'].pct_change()\n\n# Calculate 20-day Volatility\ndf['vol_20d'] = df['returns'].rolling(20).std()\n\n# Visualize the Regimes\nplt.figure(figsize=(14, 7))\nplt.subplot(2, 1, 1)\nplt.plot(df['trade_date'], df['close'])\nplt.title(\"CSI 300 Index Price\")\n\nplt.subplot(2, 1, 2)\nplt.fill_between(df['trade_date'], df['vol_20d'], color='red', alpha=0.3)\nplt.title(\"Market 'Craziness' (20-Day Volatility)\")\nplt.tight_layout()\nplt.show()\n","key":"pfGWyNqIKr"},{"type":"outputs","id":"poIZ5uBg4NxWpnCsfQ3N_","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"070fb99b4bb08c64b5d324f46bd17119","path":"/070fb99b4bb08c64b5d324f46bd17119.png"},"text/plain":{"content":"<Figure size 1400x700 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"SPrCTLmxcp"}],"key":"qmpltunqiB"}],"key":"KXkY9Hwnam"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"6. Implementing the VAA Layer (Simplified)","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"kYrsrkwMXI"}],"identifier":"id-6-implementing-the-vaa-layer-simplified","label":"6. Implementing the VAA Layer (Simplified)","html_id":"id-6-implementing-the-vaa-layer-simplified","implicit":true,"key":"Xy7pcKGoyD"},{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"Here is how the code looks. We use a small “Vol-Net” (a tiny neural network) to decide the spotlight temperature.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"kqXBWL6llj"}],"key":"Y7jHwJNd4z"}],"key":"ZmkdsMjnJ4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\n\nclass VolNet(nn.Module):\n    def __init__(self):\n        super().__init__()\n        # Takes 4 volatility scales as input\n        self.net = nn.Sequential(\n            nn.Linear(4, 16),\n            nn.ReLU(),\n            nn.Linear(16, 1), # Outputs 1 temperature scale\n            nn.Sigmoid()      # Keeps it between 0 and 1\n        )\n\n    def forward(self, vol_features):\n        # Maps 0-1 output to a useful scale, e.g., 0.5 to 2.0\n        return self.net(vol_features) * 1.5 + 0.5\n\nprint(\"The 'Thermostat' network is defined.\")\n","key":"RRuatbPfMF"},{"type":"outputs","id":"pmOdZ-Gw0zAYm5fI0INL1","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"The 'Thermostat' network is defined.\n"},"children":[],"key":"ZOphKzU4vh"}],"key":"gUWYxeEjSy"}],"key":"wMujjaqPnm"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line